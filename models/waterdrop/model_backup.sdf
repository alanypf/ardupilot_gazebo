    <!-- CCW -->
    <joint name='motor1_joint' type='revolute'>
      <pose relative_to="base_link" degrees="true">0.042836 -0.22635 -0.11141 0 90 0</pose>
      <child>motor1_link</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>0.04</damping>
        </dynamics>
      </axis>
    </joint>
    <link name="motor1_link">
      <pose relative_to="motor1_joint">0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.025</mass>
        <inertia>
          <ixx>0.000130417</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000130417</iyy>
          <iyz>0</iyz>
