<?xml version="1.0"?>
<sdf version="1.7">
  <model name="waterdrop">
    <pose>0 0 0 0 0 0</pose>
    <static>0</static>

    <link name="base_link">
      <pose degrees="true">0 0 0 0 0 0</pose>
      <!-- \todo provide proper inertial : actual mass 1.75 kg -->
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.01</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.01625</iyy>
          <iyz>0</iyz>
          <izz>0.01625</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh>
            <uri>model://waterdrop/meshes/base_link.STL</uri>
          </mesh>
        </geometry>
